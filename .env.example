# SignalWire Credentials
SIGNALWIRE_PROJECT_ID=your_project_id
SIGNALWIRE_AUTH_TOKEN=your_auth_token
SIGNALWIRE_SPACE_URL=https://your_space.signalwire.com

# Webhook Configuration
WEBHOOK_URL=https://your_webhook_url

# Application Settings
POLL_INTERVAL=10

# S3 Re-hosting (optional)
# Set S3_ENABLED=true to download recordings from SignalWire and re-host them
# on a private S3 bucket.  A presigned URL is stored in the vCon dialog so
# consumers can fetch the audio without needing SignalWire credentials.
# AWS credentials are read from the environment (AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION) or from an IAM role.
S3_ENABLED=false
S3_BUCKET=your-s3-bucket-name
S3_KEY_PREFIX=recordings/
# S3_PRESIGN_EXPIRY: presigned URL lifetime in seconds.
# AWS hard-caps this at 604800 (7 days) for IAM-user credentials.
S3_PRESIGN_EXPIRY=604800
